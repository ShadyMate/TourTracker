# Database Configuration
# Copy this file to .env and fill in your values
DB_NAME=tour_tracker
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_URL=jdbc:postgresql://postgres:5432/tour_tracker

# JWT Secret (base64-encoded, min 32 chars recommended)
JWT_SECRET=your_jwt_secret_here

# OpenRouteService API Key — get one free at https://openrouteservice.org/dev/#/signup
VITE_ORS_API_KEY=your_ors_api_key_here
